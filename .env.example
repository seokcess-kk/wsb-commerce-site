NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_xxxxxxxx
TOSS_SECRET_KEY=test_sk_xxxxxxxx
# Supabase Storage(상품 이미지 업로드). service_role 키는 서버 전용 — 클라이언트 노출 금지.
# Supabase 대시보드 > Settings > API > service_role secret 에서 복사.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# 업로드 버킷명(미설정 시 product-images). Supabase 대시보드 > Storage 에서 public 버킷으로 생성.
SUPABASE_STORAGE_BUCKET=product-images
ADMIN_EMAILS=admin@example.com
NEXT_PUBLIC_SITE_URL=https://wsb-commerce-site.vercel.app
# 결제 레이어 ON/OFF (스펙 §0 컨틴전시). 미설정=ON, "false"로 두면 소프트오픈(결제 비활성)
NEXT_PUBLIC_PAYMENTS_ENABLED=true
# 크론 엔드포인트 인증 시크릿(가상계좌 만료 스윕). 프로덕션 필수 — Vercel Cron 이 Bearer 로 전달
CRON_SECRET=your-random-cron-secret
